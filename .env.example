# AI Financial Intelligence Configuration
# Copy this file to .env and update values as needed

# System Settings
FLASK_ENV=development
DEBUG=True
PORT=5000
SECRET_KEY=your-secret-key-here

# Database (SQLite works out of the box)
DATABASE_URL=sqlite:///./ai_finance.db

# ML Model Thresholds
CONTAMINATION_RATE=0.05
RISK_THRESHOLD_BLOCK=85.0
RISK_THRESHOLD_OTP=60.0

# Google OAuth (optional — leave blank to skip)
GOOGLE_CLIENT_ID=
